{
  "name": "@caucus/backbone-server",
  "version": "0.2.0",
  "description": "Caucus standalone HTTP backbone service + HTTP client.",
  "license": "MIT",
  "author": "Caucus contributors",
  "homepage": "https://github.com/basilmentorcruise/caucus#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/basilmentorcruise/caucus.git",
    "directory": "packages/backbone-server"
  },
