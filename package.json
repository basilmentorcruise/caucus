{
  "name": "caucus",
  "version": "0.0.0",
  "private": true,
  "description": "Caucus — an agent war room for investigations & escalations.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --build --force && pnpm -r exec tsc -p tsconfig.test.json --noEmit",
    "check:anchors": "node scripts/check-md-anchors.mjs",
    "test": "node scripts/check-md-anchors.mjs && vitest run --coverage",
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.17.0",
    "@types/node": "^20.17.10",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "github-slugger": "^2.0.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  }
}
